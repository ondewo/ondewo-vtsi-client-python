# ONDEWO VTSI client SDK — example configuration (template, NO real secrets).
#
# Copy/adapt these values for your environment. Each example loads this file via
# python-dotenv (path relative to the script), then reads the variables below.
# The variable names are the canonical ONDEWO scheme — one name per concept.

# --- Connection -------------------------------------------------------------
# Hostname / IP and port of the ONDEWO VTSI services host.
ONDEWO_HOST=localhost
ONDEWO_PORT=50200

# --- Secure channel ---------------------------------------------------------
# ONDEWO_USE_SECURE_CHANNEL: true/false. When true, ONDEWO_GRPC_CERT must point
# at a PEM certificate file (leave blank for an insecure local channel).
ONDEWO_USE_SECURE_CHANNEL=false
ONDEWO_GRPC_CERT=

# --- Keycloak auth (D18 offline-token / ROPC flow) --------------------------
# Leave these blank to talk to a local, insecure dev server without auth.
# The SDK Keycloak client is PUBLIC, so there is intentionally no client secret.
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server's TLS certificate (set false only for self-signed/local).
KEYCLOAK_VERIFY_SSL=true

# --- VTSI service-specific --------------------------------------------------
# Resource name of the VTSI project the examples operate on.
ONDEWO_VTSI_PROJECT_NAME=projects/<project_uuid>/project
